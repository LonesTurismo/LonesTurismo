{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://lonesturismo.onrender.com/api/$1"
    },
    {
      "source": "/health",
      "destination": "https://lonesturismo.onrender.com/health"
    },
    {
      "source": "/admin/:path*",
      "destination": "/frontend/admin.html"
    },
    {
      "source": "/painel/:path*",
      "destination": "/frontend/painel.html"
    },
    {
      "source": "/cadastro/:path*",
      "destination": "/frontend/cadastro.html"
    },
    {
      "source": "/editar/:path*",
      "destination": "/frontend/editar.html"
    },
    {
      "source": "/admin",
      "destination": "/frontend/admin.html"
    },
    {
      "source": "/painel",
      "destination": "/frontend/painel.html"
    },
    {
      "source": "/cadastro",
      "destination": "/frontend/cadastro.html"
    },
    {
      "source": "/editar",
      "destination": "/frontend/editar.html"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/:file",
      "destination": "/frontend/:file"
    }
  ]
}
