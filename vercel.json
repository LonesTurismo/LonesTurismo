{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
   
    { "source": "/api/(.*)", "destination": "https://lonesturismo.vercel.app/api/$1" },
    { "source": "/health",   "destination": "https://lonesturismo.vercel.app/health" },

  
    { "source": "/",          "destination": "/frontend/index.html" },
    { "source": "/cadastro",  "destination": "/frontend/cadastro.html" },
    { "source": "/editar",    "destination": "/frontend/editar.html" },
    { "source": "/admin",     "destination": "/frontend/admin.html" },
    { "source": "/painel",    "destination": "/frontend/painel.html" },


    { "source": "/(.*)",      "destination": "/frontend/$1" }
  ]
}